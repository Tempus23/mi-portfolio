---
import cvData from "@/data/cv_data.json";

const { academic_formation } = cvData;
---

<div class="grid sm:grid-cols-2 gap-4 mt-6">
  {
    academic_formation.map((formation) => (
      <article
        class="relative p-5 rounded-2xl
          bg-white/60 dark:bg-white/[0.03]
          border border-gray-200/80 dark:border-white/[0.06]
          backdrop-blur-sm
          shadow-sm hover:shadow-md
          transition-shadow duration-300"
      >
        <time
          class="absolute top-4 right-4 text-xs font-medium text-gray-500 dark:text-gray-400
            bg-gray-100 dark:bg-gray-800 px-2.5 py-1 rounded-full"
        >
          {formation.date}
        </time>

        <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1 pr-16">
          {formation.title}
        </h3>
        <p class="text-sm font-medium text-indigo-600 dark:text-indigo-400 mb-2">
          {formation.company}
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          {formation.description}
        </p>
      </article>
    ))
  }
</div>