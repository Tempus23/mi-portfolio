---
import GitHub from "@/components/icons/GitHub.astro";
import Link from "@/components/icons/Link.astro";
import LinkButton from "@/components/ui/LinkButton.astro";
import cvData from "@/data/cv_data.json";

const { projects: PROJECTS_DATA } = cvData;

const TAG_COLORS: Record<string, string> = {
  Python: "bg-blue-600",
  PyTorch: "bg-orange-600",
  TensorFlow: "bg-amber-600",
  "Scikit-learn": "bg-yellow-600",
  XGBoost: "bg-red-600",
};

const PROJECTS = PROJECTS_DATA.map((project) => ({
  ...project,
  image: `/${project.image}`,
  inProgress: project.inProgress || false,
}));
---

<div class="grid gap-8 md:grid-cols-2">
  {
    PROJECTS.map(({ image, title, description, tags, link, github, inProgress }) => (
      <article
        class="group flex flex-col rounded-2xl overflow-hidden
          bg-white/60 dark:bg-white/[0.03]
          border border-gray-200/80 dark:border-white/[0.06]
          backdrop-blur-sm shadow-sm
          hover:shadow-lg hover:-translate-y-1
          transition-all duration-300"
        data-project
      >
        <div class="relative overflow-hidden">
          <img
            alt={title}
            class="w-full aspect-video object-cover object-center
              group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
            src={image}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          {inProgress && (
            <span class="absolute top-3 right-3 text-xs font-medium px-2.5 py-1 rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900/60 dark:text-amber-200 border border-amber-200/60 dark:border-amber-700/40" data-project-in-progress>
              In Progress
            </span>
          )}
        </div>

        <div class="flex flex-col flex-1 p-5">
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2" data-project-title>
            {title}
          </h3>

          <div class="flex flex-wrap gap-1.5 mb-3">
            {tags.map((tagName) => {
              const colorClass = TAG_COLORS[tagName] || "bg-gray-600";
              return (
                <span class={`text-[0.65rem] font-medium px-2 py-0.5 rounded-md text-white ${colorClass}`}>
                  {tagName}
                </span>
              );
            })}
          </div>

          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed flex-1 mb-4" data-project-description>
            {description}
          </p>

          <footer class="flex items-center gap-3 pt-3 border-t border-gray-100 dark:border-white/[0.06]">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-4" />
                Code
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Link class="size-4" />
                Preview
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>
