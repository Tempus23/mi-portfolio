---
import cvData from "@/data/cv_data.json";

const { about_me } = cvData;

function formatParagraph(paragraph: string): string {
  let formattedParagraph = paragraph;
  const boldKeywords = [
    "Artificial Intelligence",
    "Machine Learning",
    "Deep Learning",
    "AI agents",
    "backend",
    "technical leadership",
    "international experience",
    "qacodemonitor",
    "Atenea",
    "Inteligencia Artificial",
    "liderazgo técnico",
    "experiencia internacional",
  ];
  boldKeywords.forEach(keyword => {
    const regex = new RegExp(keyword, 'gi');
    formattedParagraph = formattedParagraph.replace(regex, `<strong>${keyword}</strong>`);
  });
  return formattedParagraph;
}
---

<article class="flex flex-col gap-8 text-gray-700 dark:text-gray-300">
  <div class="space-y-4 [&>p]:text-base [&>p]:leading-relaxed [&>p>strong]:text-indigo-600 dark:[&>p>strong]:text-indigo-400 [&>p>strong]:font-semibold text-pretty">
    {about_me.description_paragraphs.map((paragraph) => (
      <p set:html={formatParagraph(paragraph)} data-about-paragraph />
    ))}
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
    {about_me.attributes.map(attribute => (
      <div class="flex items-center gap-2.5 text-sm p-3 rounded-xl
        bg-white/60 dark:bg-white/[0.03]
        border border-gray-200/60 dark:border-white/[0.06]">
        <svg class="size-4 shrink-0 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span data-attribute>{attribute}</span>
      </div>
    ))}
  </div>
</article>
