---
import cvData from "@/data/cv_data.json";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import Mail from "@/components/icons/Mail.astro";
import GitHubIcon from "@/components/icons/GitHub.astro";
import SocialPill from "@/components/ui/SocialPill.astro";

const { basic_info, languages } = cvData;
const personalImageAlt = basic_info.personal_image_alt;
---

<div class="max-w-2xl mx-auto flex flex-col items-center text-center">
  <div class="flex flex-col gap-5 mb-6 items-center">
    <img
      class="rounded-2xl shadow-lg size-32 ring-2 ring-indigo-200/50 dark:ring-indigo-500/20 object-cover"
      src={`/${basic_info.image_path}`}
      alt={personalImageAlt}
    />
    <div>
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl dark:text-white">
        {basic_info.name}
      </h1>
      <p class="mt-3 text-lg font-medium text-indigo-600 dark:text-indigo-400 h-7 flex items-center justify-center" data-hero-role>
        <span id="typewriter-text"></span><span id="typewriter-cursor" class="ml-0.5 inline-block w-[2px] h-5 bg-indigo-600 dark:bg-indigo-400 animate-blink"></span>
      </p>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 flex items-center justify-center gap-1.5">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
        {basic_info.location}
      </p>
    </div>
  </div>

  <p
    class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed [&>strong]:text-indigo-600 dark:[&>strong]:text-indigo-400 [&>strong]:font-semibold"
    set:html={basic_info.tagline
      .replace(
        "Artificial Intelligence",
        "<strong>Artificial Intelligence</strong>"
      )
      .replace("Backend Development", "<strong>Backend Development</strong>")}
  />

  <nav class="flex flex-wrap justify-center gap-3 mt-8">
    <SocialPill href={`mailto:${basic_info.emails[0]}`}>
      <Mail class="size-4" />
      <span>Contact Me</span>
    </SocialPill>
    <SocialPill href={basic_info.linkedin}>
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href={basic_info.github}>
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
  </nav>
</div>

<script>
  const roles = [
    "QA Backend Developer",
    "AI/ML Engineer",
  ];

  let roleIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  const typeSpeed = 100;
  const deleteSpeed = 40;
  const pauseAfterType = 2000;
  const pauseAfterDelete = 200;

  function tick() {
    const el = document.getElementById("typewriter-text");
    if (!el) return;

    const currentRole = roles[roleIndex];

    if (!isDeleting) {
      charIndex++;
      el.textContent = currentRole.substring(0, charIndex);

      if (charIndex === currentRole.length) {
        isDeleting = true;
        setTimeout(tick, pauseAfterType);
        return;
      }
      setTimeout(tick, typeSpeed);
    } else {
      charIndex--;
      el.textContent = currentRole.substring(0, charIndex);

      if (charIndex === 0) {
        isDeleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
        setTimeout(tick, pauseAfterDelete);
        return;
      }
      setTimeout(tick, deleteSpeed);
    }
  }

  document.addEventListener("astro:page-load", () => {
    roleIndex = 0;
    charIndex = 0;
    isDeleting = false;
    const el = document.getElementById("typewriter-text");
    if (el) el.textContent = "";
    tick();
  });
</script>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 0.8s ease-in-out infinite;
  }
</style>
