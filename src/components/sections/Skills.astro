---
import cvData from "@/data/cv_data.json";

const { skills } = cvData as {
  skills: {
    technical: {
      category: string;
      items: string[];
    }[];
    competencies: string[];
  };
};

const styleMap: Record<string, { border: string; dot: string }> = {
  "Backend & Core Engineering": {
    border: "border-gray-200/80 dark:border-blue-500/20",
    dot: "bg-blue-500",
  },
  "Artificial Intelligence": {
    border: "border-gray-200/80 dark:border-purple-500/20",
    dot: "bg-purple-500",
  },
  "QA & Software Quality": {
    border: "border-gray-200/80 dark:border-emerald-500/20",
    dot: "bg-emerald-500",
  },
  "DevOps & Cloud": {
    border: "border-gray-200/80 dark:border-orange-500/20",
    dot: "bg-orange-500",
  }
};

const categories = skills.technical.map(techGroup => {
  const styles = styleMap[techGroup.category] || {
    gradient: "from-gray-500/10 to-slate-500/10 dark:from-gray-500/5 dark:to-slate-500/5",
    border: "border-gray-200/60 dark:border-gray-700/30",
    dot: "bg-gray-500",
  };
  return {
    name: techGroup.category,
    items: techGroup.items,
    ...styles
  };
});
---

<div class="space-y-10">
  <div class="grid md:grid-cols-2 gap-4">
    {categories.map(category => (
      <div
        class={`p-6 rounded-2xl bg-white dark:bg-[#0B0F19] border ${category.border} shadow-sm dark:shadow-none hover:shadow-md transition-shadow`}
      >
        <h3 class="text-lg font-bold mb-5 text-gray-900 dark:text-gray-100 flex items-center gap-2.5">
          <span>{category.name}</span>
        </h3>
        <div class="flex flex-wrap gap-2.5">
          {category.items.map(skill => (
            <span
              class="inline-flex items-center text-[13px] font-medium py-1.5 px-3.5
                bg-gray-50 dark:bg-[#1A1F2E]
                text-gray-700 dark:text-gray-300
                border border-gray-200/60 dark:border-white/5
                hover:border-gray-300 dark:hover:border-white/10
                hover:bg-gray-100 dark:hover:bg-[#22283A] transition-colors
                rounded-xl"
                          >
              {skill}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="p-6 rounded-2xl bg-white/60 dark:bg-white/[0.03] border border-gray-200/80 dark:border-white/[0.06] backdrop-blur-sm">
    <h3 class="text-base font-semibold mb-4 text-gray-800 dark:text-gray-100 flex items-center gap-2">
      <span class="text-lg">💡</span>
      <span>Professional Competencies</span>
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {skills.competencies.map(competency => (
        <div class="flex items-center gap-2.5 text-sm text-gray-600 dark:text-gray-300" >
          <svg class="size-4 shrink-0 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>{competency}</span>
        </div>
      ))}
    </div>
  </div>
</div>
